<Window x:Class="WinTermEase.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建连接" Width="440" Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{DynamicResource AppPanel2Brush}">

    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource DarkLabel}"/>
        <Style TargetType="TextBox"   BasedOn="{StaticResource DarkTextBox}"/>
        <Style TargetType="ComboBox"  BasedOn="{StaticResource DarkComboBox}"/>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="{DynamicResource AppInputBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AppFgBrush}"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppFgBrush}"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- History ComboBox -->
            <RowDefinition Height="Auto"/>  <!-- Connection name -->
            <RowDefinition Height="Auto"/>  <!-- Type selector -->
            <RowDefinition Height="*"/>     <!-- Settings panels -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── History ── -->
        <StackPanel Grid.Row="0" x:Name="PanelHistory" Margin="0,0,0,14">
            <DockPanel Margin="0,0,0,4">
                <TextBlock Text="历史连接" DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtHistoryHint" Text="（无历史记录）"
                           Foreground="{DynamicResource AppDimFgBrush}" FontSize="11"
                           DockPanel.Dock="Right" VerticalAlignment="Bottom"
                           Margin="0,0,0,1" Visibility="Collapsed"/>
            </DockPanel>
            <ComboBox x:Name="CbRecent"
                      SelectionChanged="CbRecent_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding DisplaySummary}"
                                       Foreground="{DynamicResource AppSubtleFgBrush}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- ── Connection name ── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="连接名称" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtName" Text="New Connection"/>
        </StackPanel>

        <!-- ── Type selector ── -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="连接类型" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbSerial" Content="串口 (Serial)"
                             GroupName="ConnType" IsChecked="True"
                             Margin="0,0,24,0" Checked="ConnType_Changed"/>
                <RadioButton x:Name="RbSsh" Content="SSH"
                             GroupName="ConnType" Checked="ConnType_Changed"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Serial settings ── -->
        <Grid x:Name="PanelSerial" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,10">
                <TextBlock Text="端口" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbPort" IsEditable="True"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,10">
                <TextBlock Text="波特率" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbBaud" IsEditable="True"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,10">
                <TextBlock Text="数据位" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbDataBits">
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem>7</ComboBoxItem>
                    <ComboBoxItem>6</ComboBoxItem>
                    <ComboBoxItem>5</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,0,0,10">
                <TextBlock Text="校验位" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbParity">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>Even</ComboBoxItem>
                    <ComboBoxItem>Odd</ComboBoxItem>
                    <ComboBoxItem>Mark</ComboBoxItem>
                    <ComboBoxItem>Space</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,8,10">
                <TextBlock Text="停止位" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbStopBits">
                    <ComboBoxItem>One</ComboBoxItem>
                    <ComboBoxItem>Two</ComboBoxItem>
                    <ComboBoxItem>OnePointFive</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="2" Margin="8,0,0,10">
                <TextBlock Text="流控" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbHandshake">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>XOnXOff</ComboBoxItem>
                    <ComboBoxItem>RequestToSend</ComboBoxItem>
                    <ComboBoxItem>RequestToSendXOnXOff</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- ── SSH settings ── -->
        <Grid x:Name="PanelSsh" Grid.Row="3" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,10">
                <TextBlock Text="主机" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtHost"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="端口" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtSshPort" Text="22"/>
            </StackPanel>

            <StackPanel Grid.ColumnSpan="2" Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="用户名" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUser"/>
            </StackPanel>

            <StackPanel Grid.ColumnSpan="2" Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="密码" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PbPassword"/>
            </StackPanel>

            <StackPanel Grid.ColumnSpan="2" Grid.Row="3" Margin="0,0,0,8">
                <CheckBox x:Name="ChkUseKey" Content="使用私钥文件"
                          Checked="ChkUseKey_Checked" Unchecked="ChkUseKey_Checked"/>
            </StackPanel>

            <Grid Grid.ColumnSpan="2" Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtKeyPath" IsEnabled="False"
                         Background="{DynamicResource AppInputBgBrush}"/>
                <Button Grid.Column="1" Content="浏览" Margin="6,0,0,0"
                        Style="{StaticResource DarkButton}" IsEnabled="False"
                        x:Name="BtnBrowseKey" Click="BtnBrowseKey_Click"/>
            </Grid>
        </Grid>

        <!-- ── Buttons ── -->
        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <Button Content="取消" DockPanel.Dock="Right" Width="80"
                    Style="{StaticResource DarkButton}" Click="BtnCancel_Click"/>
            <Button Content="连接" DockPanel.Dock="Right" Width="80" Margin="0,0,8,0"
                    Style="{StaticResource AccentButton}" Click="BtnConnect_Click"/>
        </DockPanel>
    </Grid>
</Window>
