<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Semantic brushes (referenced by styles) ── -->
    <SolidColorBrush x:Key="AppBgBrush"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppPanelBrush"        Color="#F3F3F3"/>
    <SolidColorBrush x:Key="AppPanel2Brush"       Color="#EBEBEB"/>
    <SolidColorBrush x:Key="AppBorderBrush"       Color="#D4D4D4"/>
    <SolidColorBrush x:Key="AppFgBrush"           Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppSubtleFgBrush"     Color="#767676"/>
    <SolidColorBrush x:Key="AppDimFgBrush"        Color="#BBBBBB"/>
    <SolidColorBrush x:Key="AppInputBgBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppInputBorderBrush"  Color="#CECECE"/>
    <SolidColorBrush x:Key="AppHoverBrush"        Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AppSelectionBrush"    Color="#ADD6FF"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#0078D4"/>

    <!-- Tab state indicator colors -->
    <SolidColorBrush x:Key="TabConnectedFgBrush"    Color="#0078D4"/>
    <SolidColorBrush x:Key="TabConnectingFgBrush"   Color="#B8860B"/>
    <SolidColorBrush x:Key="TabErrorFgBrush"        Color="#CC0000"/>
    <SolidColorBrush x:Key="TabDisconnectedFgBrush" Color="#767676"/>

    <!-- Legacy keys kept for any direct references -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBrush"       Color="#EBEBEB"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TabActiveBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabInactiveBrush" Color="#F3F3F3"/>

</ResourceDictionary>
