<Window x:Class="WindowsTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowsTerminal.ViewModels"
        xmlns:conv="clr-namespace:WindowsTerminal.Converters"
        Title="Windows Terminal" Height="700" Width="1100"
        MinHeight="400" MinWidth="600"
        Background="#1E1E1E"
        WindowState="Normal">

    <Window.Resources>
        <conv:CommandDisplayConverter x:Key="CmdDisplayConverter"/>

        <!-- Tab header button -->
        <Style x:Key="TabHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0,8,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active tab header -->
        <Style x:Key="ActiveTabHeaderButton" TargetType="Button" BasedOn="{StaticResource TabHeaderButton}">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Quick command button -->
        <Style x:Key="QuickCmdButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group filter button (inactive) -->
        <Style x:Key="GroupFilterButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group filter button (active/selected) -->
        <Style x:Key="ActiveGroupFilterButton" TargetType="Button" BasedOn="{StaticResource GroupFilterButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- Toolbar -->
            <RowDefinition Height="34"/>   <!-- Tab strip -->
            <RowDefinition Height="*"/>    <!-- Terminal area -->
            <RowDefinition Height="Auto"/> <!-- Quick commands -->
            <RowDefinition Height="26"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <TextBlock Text="⚡ WinTerminal" Foreground="#CCCCCC" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,20,0" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <Button Content="＋ 串口" Style="{StaticResource DarkButton}"
                            Command="{Binding NewSerialCommand}" Margin="0,0,6,0" Padding="10,4"/>
                    <Button Content="＋ SSH" Style="{StaticResource DarkButton}"
                            Command="{Binding NewSshCommand}" Padding="10,4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            DockPanel.Dock="Right">
                    <Button Content="保存日志" Style="{StaticResource DarkButton}" Padding="8,4"
                            Click="BtnSaveLog_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnToggleQuickBar" Content="快捷栏 ▾"
                            Style="{StaticResource DarkButton}" Padding="8,4"
                            Click="BtnToggleQuickBar_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Tab strip ═══ -->
        <Border Grid.Row="1" Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <DockPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              DockPanel.Dock="Left" x:Name="TabScrollViewer">
                    <StackPanel Orientation="Horizontal" x:Name="TabStrip"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ Terminal area ═══ -->
        <Grid Grid.Row="2" x:Name="TerminalArea" Background="#1E1E1E">
            <TextBlock x:Name="NoTabHint"
                       Text="点击「＋ 串口」或「＋ SSH」新建连接"
                       Foreground="#555555" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- ═══ Quick command bar (2 rows: group filter + commands) ═══ -->
        <Border Grid.Row="3" x:Name="QuickCommandBar"
                Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                MinHeight="52" MaxHeight="108">
            <StackPanel Margin="6,2,6,2">

                <!-- Row 1: group filter tabs + add button -->
                <DockPanel Height="26">
                    <Button DockPanel.Dock="Right" Content="＋" Width="26" Height="22"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding AddQuickCommandCommand}"
                            ToolTip="添加快捷指令" VerticalAlignment="Center" Margin="4,0,0,0"
                            FontSize="13" Padding="0"/>
                    <TextBlock DockPanel.Dock="Left" Text="分组："
                               Foreground="#555555" VerticalAlignment="Center"
                               FontSize="11" Margin="0,0,4,0"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <!-- Group buttons generated in code-behind -->
                        <StackPanel x:Name="GroupFilterPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                    </ScrollViewer>
                </DockPanel>

                <!-- Row 2: command buttons for the selected group -->
                <DockPanel Height="30">
                    <TextBlock DockPanel.Dock="Left" Text="指令："
                               Foreground="#555555" VerticalAlignment="Center"
                               FontSize="11" Margin="0,0,4,0"/>
                    <!-- Container clips overflow; StackPanel filled by code-behind -->
                    <Grid x:Name="QuickCmdContainerGrid" ClipToBounds="True"
                          SizeChanged="QuickCmdArea_SizeChanged">
                        <StackPanel x:Name="QuickCmdStrip" Orientation="Horizontal"
                                    VerticalAlignment="Center"/>
                        <!-- "···" overflow button — overlay at right edge, does NOT affect container width -->
                        <Button x:Name="BtnMoreCmds"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Content="···" Width="28" Height="22"
                                Style="{StaticResource DarkButton}"
                                Visibility="Collapsed"
                                Click="BtnMoreCmds_Click"
                                ToolTip="更多指令" FontSize="14"/>
                    </Grid>
                </DockPanel>

            </StackPanel>
        </Border>

        <!-- ═══ Status bar ═══ -->
        <Border Grid.Row="4" Background="#007ACC">
            <DockPanel Margin="8,0">
                <TextBlock x:Name="TxtStatus"
                           Text="{Binding StatusText}"
                           Foreground="White" FontSize="12" DockPanel.Dock="Left"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <TextBlock Text="RX: " Foreground="#B0D8FF" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RxDisplay}" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="TX: " Foreground="#B0D8FF" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TxDisplay}" Foreground="White" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
